pipeline {
    agent none

    options {
        buildDiscarder(logRotator(numToKeepStr: '2'))
        ansiColor('xterm')
    }

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'main', description: 'Branch name to build')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'stage', 'prod'], description: 'Target environment')
    }

    environment {
        APP_NAME = 'myapp'
        DOCKER_IMAGE = 'myimage:latest'
        // FIX: Use Groovy logic instead of 'sh' so it doesn't require an agent/node
        TIMESTAMP = "${new Date().format('yyyyMMdd-HHmmss')}"
    }

    stages {
        stage('Parallel Testing') {
            parallel {
                stage('Windows Testing') {
                    agent { label 'slave1' }
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                            retry(3) {
                                echo "Running Windows tests on Branch: ${params.BRANCH_NAME}"
                            }
                        }
                    }
                }
                stage('Linux Testing') {
                    agent { label 'slave2' }
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                            retry(3) {
                                echo "Running Linux tests on Branch: ${params.BRANCH_NAME}"
                            }
                        }
                    }
                }
                stage('Mac Testing') {
                    agent { label 'slave2' }
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                            retry(3) {
                                echo "Running Mac tests on Branch: ${params.BRANCH_NAME}"
                            }
                        }
                    }
                }
            }
        }

        stage('Staging') {
            agent { label 'master' }
            steps {
                script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                        // This will fail as requested, but allow the pipeline to continue
                        sh 'exit 1'
                    }
                }
                echo "Environment: ${params.ENVIRONMENT}"
            }
        }

        stage('Production') {
            agent { label 'slave1' }
            steps {
                echo "Deploying ${env.APP_NAME} version ${env.TIMESTAMP} to Production"
            }
        }
    }

    post {
        success {
            echo "✓ Completed successfully at ${env.TIMESTAMP}"
        }
        failure {
            echo "✗ Pipeline failed!"
        }
        always {
            echo "Execution finished. Build ID: ${env.BUILD_ID}"
        }
    }
}