pipeline{
    agent none
    parameters{
        string(name: 'Name', defaultValue: '', description: 'Enter your name')
        booleanParam(name: 'skiptest', defaultValue:false, description: 'skip the level of testing')
        choice(name: 'Environment', choices: ['dev', 'qa', 'prod'], description: 'Select the environment')
    }
    stages{
        stage('Build'){
            agent {label 'slave2'}
            steps{
                echo "Name: ${params.Name}" 
                echo "Environment: ${params.Environment}"
                echo "Skip Test: ${params.skiptest}"
            }
        }
        stage('Test'){
            agent {label 'slave1'}
            steps{
                echo 'Testing...'
            }
        }
        stage('Deploy'){
            steps{
                echo 'Deploying...'
            }
        }
    }
}