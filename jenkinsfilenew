pipeline {

    properties([
        buildDiscarder(logRotator(numToKeepStr: '2'))
    ])

    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'main', description: 'Branch name to build')
        choice(name: 'ENVIRONMENT', choices: ['dev', 'stage', 'prod'], description: 'Target environment')
    }
    environment {
        APP_NAME = 'myapp'
        DOCKER_IMAGE = 'myimage:latest'
    }
        agent none
        stages {
            stage('parallel testing') {
                steps {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        parallel {
                            stage('windows testing') {
                                agent { label  'slave1' }
                                steps {
                                    retry(3) {
                                        echo 'this is windows testing'
                                        echo "Branch: ${params.BRANCH_NAME}"
                                    }
                                }
                            }
                            stage('linux testing') {
                                agent { label  'slave2' }
                                steps {
                                    retry(3) {
                                        echo 'this is linux testing'
                                        echo "Branch: ${params.BRANCH_NAME}"
                                    }
                                }
                            }
                            stage('mac testing') {
                                agent { label  'slave2' }
                                steps {
                                    retry(3) {
                                        echo 'this is mac testing'
                                        echo "Branch: ${params.BRANCH_NAME}"
                                    }
                                }
                            }
                        }
                    }
                }
            }
            stage('staging') {
                agent { label  'master' }
                steps {
                    script {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh '''
                            echo "this is running"
                            exit 1
                            '''
                        }
                    }
                    echo "Environment: ${params.ENVIRONMENT}"
                }
            }
            stage('production') {
                agent { label  'slave1' }
                steps {
                    echo 'this is production stage'
                    echo "App: ${env.APP_NAME}, Image: ${env.DOCKER_IMAGE}"
                }
            }
        }
    post {
        success {
            echo "✓ Pipeline completed successfully!"
            echo "Branch: ${params.BRANCH_NAME} | Environment: ${params.ENVIRONMENT}"
        }
        failure {
            echo "✗ Pipeline failed!"
            echo "App: ${env.APP_NAME} | Image: ${env.DOCKER_IMAGE}"
        }
        unstable {
            echo "⚠ Pipeline completed with warnings"
        }
        always {
            echo "Pipeline execution finished at: ${env.BUILD_TIMESTAMP}"
        }
    }
}
